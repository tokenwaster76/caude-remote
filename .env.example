# Required: Bearer token for authenticating requests (min 32 chars)
AUTH_TOKEN=

# Port for the local MCP server
PORT=3000

# Semicolon-separated list of directories the server can read/write/execute in
ALLOWED_PATHS=C:\Users\Mario

# Command timeout in milliseconds (default: 30s)
COMMAND_TIMEOUT_MS=30000

# Maximum allowed timeout per command call (default: 5 min)
MAX_COMMAND_TIMEOUT_MS=300000

# Set to true to allow shell operators (pipes, &&, ||) in commands
ALLOW_SHELL_OPERATORS=false

# Your Cloudflare tunnel hostname (set after first tunnel run, used for Host header validation)
TUNNEL_HOSTNAME=
